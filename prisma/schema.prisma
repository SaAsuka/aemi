generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TalentStatus {
  ACTIVE
  INACTIVE
  WITHDRAWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  RESUME_SENT
  ACCEPTED
  REJECTED
  AUTO_REJECTED
  CANCELLED
}

enum ScheduleStatus {
  CONFIRMED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum AuthTokenType {
  INVITE
  PASSWORD_RESET
}

enum JobDateType {
  AUDITION
  SHOOTING
  OTHER
}

enum SubmissionCategory {
  ACTING_VIDEO
  VOICE_SAMPLE
  PAST_WORK_VIDEO
  PROFILE_PHOTO
}

model Talent {
  id             String       @id @default(cuid())
  lastName       String       @default("")
  firstName      String       @default("")
  lastNameKana   String       @default("")
  firstNameKana  String       @default("")
  name           String
  nameKana       String
  stageName      String?
  nameRomaji   String?
  email        String?
  phone        String?
  gender       Gender?
  birthDate    DateTime?
  height       Int?
  bust         Int?
  waist        Int?
  hip          Int?
  shoeSize     Float?
  skills       String?
  hobbies      String?
  qualifications String?
  career       String?      @db.Text
  category     String?
  birthplace   String?
  address      String?
  representativeWork String? @db.Text
  lineUserId   String?
  profileImage String?
  resume         String?
  resumeSource   String?            @default("auto")
  nearestStation String?
  instagramUrl   String?
  xUrl           String?
  tiktokUrl      String?
  websiteUrl     String?
  bankName       String?
  bankBranch     String?
  bankAccountType  String?
  bankAccountNumber String?
  bankAccountHolder String?
  passwordHash         String?
  mustChangePassword   Boolean            @default(false)
  accessToken          String?            @unique @default(cuid())
  emailVerified        Boolean            @default(false)
  stripeCustomerId     String?            @unique
  subscriptionStatus   SubscriptionStatus @default(NONE)
  subscriptionId       String?            @unique
  currentPeriodEnd     DateTime?
  status               TalentStatus       @default(ACTIVE)
  note                 String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  applications Application[]
  photos       TalentPhoto[]
  works        TalentWork[]

  @@map("talents")
}

model TalentPhoto {
  id        String   @id @default(cuid())
  talentId  String
  talent    Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([talentId])
  @@map("talent_photos")
}

model TalentWork {
  id        String   @id @default(cuid())
  talentId  String
  talent    Talent   @relation(fields: [talentId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([talentId])
  @@map("talent_works")
}

model Client {
  id           String   @id @default(cuid())
  companyName  String
  contactName  String?
  contactEmail String?
  contactPhone String?
  lineGroupId  String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs Job[]

  @@map("clients")
}

model Job {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  title       String
  description String?
  location    String?
  fee         Int?
  genderReq   Gender?
  ageMin      Int?
  ageMax      Int?
  heightMin   Int?
  heightMax   Int?
  deadline    DateTime?
  capacity    Int?
  status      JobStatus @default(DRAFT)
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  applications Application[]
  requirements JobRequirement[]
  dates        JobDate[]

  @@index([clientId])
  @@index([status])
  @@map("jobs")
}

model JobDate {
  id        String      @id @default(cuid())
  jobId     String
  job       Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      JobDateType
  date      DateTime
  startTime String?
  endTime   String?
  location  String?
  note      String?

  @@index([jobId])
  @@map("job_dates")
}

model Application {
  id        String            @id @default(cuid())
  talentId  String
  talent    Talent            @relation(fields: [talentId], references: [id])
  jobId     String
  job       Job               @relation(fields: [jobId], references: [id])
  status          ApplicationStatus @default(APPLIED)
  appliedAt       DateTime          @default(now())
  decidedAt       DateTime?
  note            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  schedule    Schedule?
  submissions ApplicationSubmission[]

  @@unique([talentId, jobId])
  @@index([talentId])
  @@index([jobId])
  @@index([status])
  @@map("applications")
}

model Schedule {
  id            String         @id @default(cuid())
  applicationId String         @unique
  application   Application    @relation(fields: [applicationId], references: [id])
  date          DateTime
  startTime     String?
  endTime       String?
  location      String?
  status        ScheduleStatus @default(CONFIRMED)
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([date])
  @@map("schedules")
}

model JobRequirement {
  id            String             @id @default(cuid())
  jobId         String
  job           Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category      SubmissionCategory
  description   String?
  referenceUrl  String?
  referenceFile String?

  @@unique([jobId, category])
  @@index([jobId])
  @@map("job_requirements")
}

model AuthToken {
  id        String        @id @default(cuid())
  token     String        @unique
  email     String
  type      AuthTokenType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([token])
  @@index([email])
  @@map("auth_tokens")
}

model ApplicationSubmission {
  id            String             @id @default(cuid())
  applicationId String
  application   Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  category      SubmissionCategory
  fileUrl       String?
  externalUrl   String?
  fileName      String?
  createdAt     DateTime           @default(now())

  @@unique([applicationId, category])
  @@index([applicationId])
  @@map("application_submissions")
}
